{
    "name": "quillstack/di",
    "description": "The dependency injection container based on PSR-11: Container interface, and with the main goal: to be fast.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://quillstack.com/di",
    "authors": [
        {
            "name": "Radek Ziemniewicz",
            "email": "radoslaw@ziemniewicz.pl"
        }
    ],
    "require": {
        "php": "^7.4",
        "psr/container": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "QuillStack\\DI\\": "src/QuillStack/DI/",
            "QuillStack\\Mocks\\DI\\": "tests/QuillStack/Mocks/DI/"
        }
    },
    "require-dev": {
        "symfony/var-dumper": "^5.1",
        "phpunit/phpunit": "^9"
    }
}
